# Supabase
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_API_KEY=

# Admin
SUPER_ADMIN_EMAILS=admin@example.com

# Seed (optional — only needed for pnpm db:seed)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# LemonSqueezy
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=

# Email (Resend) — si no está seteado, sendEmail() hace noop con warn
RESEND_API_KEY=
CONTACT_EMAIL=hola@aerolume.com
QUOTES_FROM_EMAIL=presupuestos@aerolume.com

# Rate limiting (Upstash Redis) — crear DB en upstash.com y copiar REST URL + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 2FA super admins — opt-in. '1' fuerza MFA; cualquier otro valor (o ausente) deja el gate off
ENFORCE_SUPER_ADMIN_MFA=
